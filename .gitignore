# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
build/

# Environment — NEVER commit real env files
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache / temp
.cache/
.vite/
*.tmp
*.temp

# Financial data — personal files must never be versioned
*.xlsx
*.xls
*.csv
*.ofx
*.qif
*.ods

# SQL dumps and backups (migrations in supabase/migrations/ are versioned)
*.sql
!supabase/migrations/*.sql
*.dump
*.bak
*.backup
backups/
dumps/

# Deploy artifacts (built zips and extracted dist folders)
*.tar.gz
*.zip
deploy-fin/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json

# TypeScript build info
*.tsbuildinfo
