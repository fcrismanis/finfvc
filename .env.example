# Data provider: 'local' (default) or 'supabase'
# local  — uses localStorage (no backend needed)
# supabase — requires VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY below
#            falls back to local if either var is missing
VITE_DATA_PROVIDER=local

# Supabase — only required when VITE_DATA_PROVIDER=supabase
# Never commit .env to git
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
