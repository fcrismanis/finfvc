# =============================================================
# FINANCE — Environment variables reference
# Copy to finance-app/.env.local and fill in real values.
# Never commit .env.local or any file with real secrets.
# =============================================================

# ── Data provider ─────────────────────────────────────────────
# 'local'    — localStorage only, no backend needed (default)
# 'supabase' — requires VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY
#              falls back to local if either var is missing
VITE_DATA_PROVIDER=local

# ── Supabase ──────────────────────────────────────────────────
# Only required when VITE_DATA_PROVIDER=supabase
# Use the anon/publishable key ONLY — never the secret/service-role key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-anon-key-here
